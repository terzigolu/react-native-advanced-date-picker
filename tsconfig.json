{
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "react-native-advanced-date-picker": ["./src/index"]
    },
"strict": true,
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext"],
    "allowJs": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./lib",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "example"]
}
