{
  "name": "react-native-advanced-date-picker",
  "version": "0.3.0",
  "description": "Zero-dependency, fully customizable React Native calendar date picker. Single, range & multi-select; week/month/year/time/datetime views; presets; per-date badges; accessibility; non-Gregorian calendars (Hijri, Persian, Buddhist); optional web support; headless useDatePicker() hook.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "build": "bob build",
    "typescript": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "prepare": "bob build",
    "prepublishOnly": "yarn typescript && yarn test && yarn build",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "example": "yarn --cwd example start"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "react-native",
    "date-picker",
    "calendar",
    "datepicker",
    "date-range",
    "range-picker",
    "multi-select",
    "week-picker",
    "month-picker",
    "year-picker",
    "time-picker",
    "datetime-picker",
    "i18n",
    "customizable",
    "themeable",
    "headless",
    "accessibility",
    "a11y",
    "hijri",
    "persian",
    "jalali",
    "buddhist",
    "presets",
    "booking",
    "ios",
    "android",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terzigolu/react-native-advanced-date-picker.git"
  },
  "author": "Ucuz Yolu <info@ucuzyolu.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/terzigolu/react-native-advanced-date-picker/issues"
  },
  "homepage": "https://github.com/terzigolu/react-native-advanced-date-picker#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-flow": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native/js-polyfills": "^0.84.1",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.1.0",
    "react": "^18.2.0",
    "react-dom": "18.3.1",
    "react-native": "^0.73.0",
    "react-native-builder-bob": "^0.23.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "18.2.0",
    "storybook": "^10.3.5",
    "typescript": "^5.3.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.63.0",
    "react-native-safe-area-context": "*",
    "react-native-web": "*"
  },
  "peerDependenciesMeta": {
    "react-native-safe-area-context": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": [
      "**/{__tests__,__fixtures__,__mocks__}/**",
      "**/*.stories.@(ts|tsx)"
    ],
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
