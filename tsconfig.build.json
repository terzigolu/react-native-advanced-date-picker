{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./lib/typescript"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "lib",
    "example",
    ".storybook",
    "**/__tests__",
    "**/*.stories.ts",
    "**/*.stories.tsx"
  ]
}
